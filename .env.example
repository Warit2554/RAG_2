OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_ROUTER_MODEL=llama3.1:8b
OLLAMA_ORCHESTRATOR_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_local_chunks
RAG_DATA_DIR=./data
SEARXNG_URL=http://localhost:8080
RAG_MAX_CHUNK_TOKENS=320
RAG_TOP_K=5
RAG_KEEP_ALIVE=1h

# ─────────────────────────────────────────────
# MCP Server Credentials (optional per server)
# ─────────────────────────────────────────────
# GitHub MCP Server — create token at https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Firecrawl MCP Server — get key at https://firecrawl.dev
FIRECRAWL_API_KEY=

# Postgres MCP Server — full connection string
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/mydb
